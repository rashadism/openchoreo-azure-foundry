# ---- Telemetry (agent -> Application Insights) --------------------------------
# Connection string of the App Insights resource CONNECTED to your Foundry project.
# This is the ONLY credential telemetry needs. It is NOT Entra / not a service principal.
APPLICATIONINSIGHTS_CONNECTION_STRING="InstrumentationKey=00000000-0000-0000-0000-000000000000;IngestionEndpoint=https://<region>.in.applicationinsights.azure.com/;LiveEndpoint=https://<region>.livediagnostics.monitor.azure.com/"

# ---- Model call (agent -> Foundry Responses API) ------------------------------
# Foundry project endpoint (Overview page of the project in the Foundry portal).
FOUNDRY_PROJECT_ENDPOINT="https://<your-project>.services.ai.azure.com/api/projects/<project-name>"
# Model deployment name to invoke via the Responses API.
MODEL_DEPLOYMENT="gpt-4o-mini"

# Service principal used by DefaultAzureCredential (scope https://ai.azure.com/.default).
AZURE_CLIENT_ID="<sp-app-id>"
AZURE_TENANT_ID="<tenant-id>"
AZURE_CLIENT_SECRET="<sp-secret>"

# ---- Agent identity + server --------------------------------------------------
# Emitted as gen_ai.agent.id on every span; MUST equal the otel_agent_id used at
# registration time in Foundry, or traces won't attach to the agent record.
AGENT_ID="openchoreo-telemetry-agent-v1"
AGENT_NAME="OpenChoreo Telemetry Agent"
PORT="8080"
