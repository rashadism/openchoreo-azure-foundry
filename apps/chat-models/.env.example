# --- Foundry project ---------------------------------------------------------
FOUNDRY_PROJECT_ENDPOINT=https://<your-account>.services.ai.azure.com/api/projects/<your-project>

# --- Model deployment names (injected by OpenChoreo from the model Resources) -
MODEL_1=gpt-5-mini
MODEL_2=gpt-5-nano
MODEL_3=gpt-5.1

# --- App ---------------------------------------------------------------------
PORT=8080

# --- Entra service principal (DO NOT COMMIT REAL VALUES) ---------------------
# Read automatically by azure-identity DefaultAzureCredential.
# In OpenChoreo these come from the platform secret store, not this file.
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=
