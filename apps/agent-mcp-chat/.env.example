# ---- Foundry project (Entra-only; no API key for agents) --------------------
FOUNDRY_PROJECT_ENDPOINT=https://rashad-4421-resource.services.ai.azure.com/api/projects/rashad-4421
AGENT_NAME=mcp-agent
PORT=8080

# Model deployment used by create_agent.py (must exist in the project)
FOUNDRY_MODEL_DEPLOYMENT=gpt-5-mini

# MCP tool (public, tokenless). Override to point at a different public MCP server.
MCP_SERVER_LABEL=api-specs
MCP_SERVER_URL=https://gitmcp.io/Azure/azure-rest-api-specs

# ---- Service principal creds consumed by DefaultAzureCredential -------------
# Provided at runtime via a SecretReference / platform secret store (see README).
# For local dev you can instead run `az login` and omit these.
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=
